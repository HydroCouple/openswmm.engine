/**
 * @file legacy_version.h
 * @brief Auto-generated version information for the Legacy SWMM Engine.
 *
 * This file is generated by CMake from legacy_version.h.in at configure time.
 * Do not edit manually.
 */
#ifndef LEGACY_SWMM_VERSION_H
#define LEGACY_SWMM_VERSION_H

/** @brief Legacy SWMM major version number. */
#define LEGACY_SWMM_VERSION_MAJOR       @LEGACY_SWMM_VERSION_MAJOR@

/** @brief Legacy SWMM minor version number. */
#define LEGACY_SWMM_VERSION_MINOR       @LEGACY_SWMM_VERSION_MINOR@

/** @brief Legacy SWMM patch version number. */
#define LEGACY_SWMM_VERSION_PATCH       @LEGACY_SWMM_VERSION_PATCH@

/** @brief Legacy SWMM version string (e.g. "5.3.0"). */
#define LEGACY_SWMM_VERSION             "@LEGACY_SWMM_VERSION@"

/** @brief Legacy SWMM full version string including build tag. */
#define LEGACY_SWMM_VERSION_FULL        "@LEGACY_SWMM_VERSION_FULL@"

/** @brief Integer version in SWMM-compatible format: MAJOR*10000 + MINOR*1000 + PATCH. */
#define LEGACY_SWMM_VERSION_INT         (LEGACY_SWMM_VERSION_MAJOR * 10000 \
                                       + LEGACY_SWMM_VERSION_MINOR * 1000  \
                                       + LEGACY_SWMM_VERSION_PATCH)

/* Backwards-compatibility aliases used by existing legacy code */

/** @brief VERSION macro used throughout legacy code (integer format). */
#define PROJECT_VERSION_SWMM_FORMAT     LEGACY_SWMM_VERSION_INT

#endif /* LEGACY_SWMM_VERSION_H */

/**
 * @file version.h
 * @brief Auto-generated version information for the OpenSWMM Engine.
 *
 * This file is generated by CMake from version.h.in at configure time.
 * Do not edit manually.
 *
 * @defgroup engine_version Version Information
 * @ingroup new_engine
 */
#ifndef OPENSWMM_VERSION_H
#define OPENSWMM_VERSION_H

/* -----------------------------------------------------------------------
 * OpenSWMM Engine version macros (primary)
 * ----------------------------------------------------------------------- */

/** @brief Project name string. */
#define OPENSWMM_PROJECT_NAME        "@PROJECT_NAME@"

/** @brief Major version number (breaking changes). */
#define OPENSWMM_VERSION_MAJOR       @PROJECT_VERSION_MAJOR@

/** @brief Minor version number (new features, backward compatible). */
#define OPENSWMM_VERSION_MINOR       @PROJECT_VERSION_MINOR@

/** @brief Patch version number (bug fixes). */
#define OPENSWMM_VERSION_PATCH       @PROJECT_VERSION_PATCH@

/** @brief Version string without pre-release tag (e.g. "6.0.0"). */
#define OPENSWMM_VERSION             "@PROJECT_VERSION@"

/** @brief Pre-release tag string (e.g. "alpha.1", "beta.1", "rc.1", ""). */
#define OPENSWMM_VERSION_PRERELEASE  "@OPENSWMM_PRERELEASE@"

/** @brief Full version string including pre-release tag (e.g. "6.0.0-alpha.1"). */
#define OPENSWMM_VERSION_FULL        "@OPENSWMM_FULL_VERSION@"

/** @brief Integer version in SWMM-compatible format: MAJOR*10000 + MINOR*1000 + PATCH. */
#define OPENSWMM_VERSION_INT         (OPENSWMM_VERSION_MAJOR * 10000 \
                                    + OPENSWMM_VERSION_MINOR * 1000  \
                                    + OPENSWMM_VERSION_PATCH)

/** @brief Git commit hash of the build (short form). */
#define OPENSWMM_BUILD_COMMIT        "@OPENSWMMCORE_GIT_HASH@"

/** @brief Build date string (set by CI, may be empty in local builds). */
#define OPENSWMM_BUILD_DATE          "@BUILD_DATE@"

/** @brief Build branch name (set by CI, may be empty in local builds). */
#define OPENSWMM_BUILD_BRANCH        "@BUILD_BRANCH@"

/* -----------------------------------------------------------------------
 * Legacy / backwards-compatibility macros (deprecated: use OPENSWMM_ prefix)
 * ----------------------------------------------------------------------- */

/** @deprecated Use OPENSWMM_PROJECT_NAME */
#define PROJECT_NAME                 OPENSWMM_PROJECT_NAME

/** @deprecated Use OPENSWMM_VERSION_MAJOR */
#define PROJECT_VERSION_MAJOR        OPENSWMM_VERSION_MAJOR

/** @deprecated Use OPENSWMM_VERSION_MINOR */
#define PROJECT_VERSION_MINOR        OPENSWMM_VERSION_MINOR

/** @deprecated Use OPENSWMM_VERSION_PATCH */
#define PROJECT_VERSION_PATCH        OPENSWMM_VERSION_PATCH

/** @deprecated Use OPENSWMM_VERSION */
#define PROJECT_VERSION              OPENSWMM_VERSION

/** @deprecated Use OPENSWMM_VERSION_PRERELEASE */
#define PROJECT_VERSION_PRERELEASE   OPENSWMM_VERSION_PRERELEASE

/** @deprecated Use OPENSWMM_VERSION_FULL */
#define PROJECT_VERSION_FULL         OPENSWMM_VERSION_FULL

/** @deprecated Use OPENSWMM_VERSION_INT */
#define PROJECT_VERSION_SWMM_FORMAT  OPENSWMM_VERSION_INT

/** @deprecated Use OPENSWMM_BUILD_COMMIT */
#define BUILD_COMMIT                 OPENSWMM_BUILD_COMMIT

/** @deprecated Use OPENSWMM_BUILD_DATE */
#define BUILD_DATE                   OPENSWMM_BUILD_DATE

/** @deprecated Use OPENSWMM_BUILD_BRANCH */
#define BUILD_BRANCH                 OPENSWMM_BUILD_BRANCH

#endif /* OPENSWMM_VERSION_H */
